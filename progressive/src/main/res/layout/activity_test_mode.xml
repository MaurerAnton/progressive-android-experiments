<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="8dp">

    <TextView
        android:id="@+id/testStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test Mode — No Account Required"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:padding="8dp"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/testSearchInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search messages..."
            android:textColorHint="#888"
            android:textColor="#fff"
            android:background="#2a2a4a"
            android:padding="8dp" />

        <Button
            android:id="@+id/testSearchBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search"
            android:textColor="#fff" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rooms:"
        android:textColor="#aaa"
        android:textSize="12sp"
        android:padding="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/testRoomList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#16213e" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Messages:"
        android:textColor="#aaa"
        android:textSize="12sp"
        android:padding="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/testMessageList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:background="#0f3460"
        android:visibility="gone" />

</LinearLayout>
